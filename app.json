{
  "expo": {
    "name": "FincaApp",
    "slug": "FincaApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logos.png",
    "scheme": "fincaapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      // 👇 Apunta a la nueva imagen combinada (Lienzo 1280x1920)
      "image": "./assets/images/splash-logo.png",
      "resizeMode": "contain", 
      "backgroundColor": "#065F46"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logos.png",
        "backgroundColor": "#065F46"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": ""
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}